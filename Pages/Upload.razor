@page "/upload"
@inject HttpClient Http

<h3>Multipart upload to S3 (presigned, no custom domain)</h3>

<InputFile OnChange="OnInputFileChange" />
<p>@_status</p>
<p>Progress: @_progress:F1%</p>

@code {
    private string _status = "";
    private double _progress = 0;

    private const long MinS3PartSize = 5L * 1024 * 1024;  // 5 MB (except last)  // AWS requirement
    private const long DefaultPartSize = 10L * 1024 * 1024; // 10 MB

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) { _status = "No file selected."; return; }

        var partSize = DefaultPartSize;
        var totalParts = (int)Math.Ceiling((double)file.Size / partSize);

        _status = $"Preparing upload of {file.Name} ({file.Size / (1024 * 1024):F2} MB) in {totalParts} parts...";
        StateHasChanged();

        // 1) Ask backend to INIT multipart and presign UploadPart URLs using S3 default (virtual-hosted) endpoint
        var initReq = new InitMultipartRequest(
            FileName: file.Name,
            ContentType: file.ContentType ?? "application/octet-stream",
            PartSizeBytes: partSize,
            TotalSizeBytes: file.Size);

        var initResp = await Http.PostAsJsonAsync("https://YOUR_API/init-multipart", initReq);
        initResp.EnsureSuccessStatusCode();
        var init = await initResp.Content.ReadFromJsonAsync<InitMultipartResponse>();
        if (init is null || string.IsNullOrWhiteSpace(init.UploadId)) { _status = "Init failed"; return; }

        // 2) Upload parts to presigned URLs, collect ETags
        var etags = new string[init.PartUrls.Count];
        long uploadedBytes = 0;

        using var fileStream = file.OpenReadStream(maxAllowedSize: long.MaxValue);
        var semaphore = new SemaphoreSlim(3); // limit concurrent uploads
        var tasks = new List<Task>();

        for (int partIndex = 0; partIndex < init.PartUrls.Count; partIndex++)
        {
            var bytesToRead = (int)Math.Min(partSize, file.Size - (long)partIndex * partSize);
            var ms = new MemoryStream(bytesToRead);
            await CopyFixedBytesAsync(fileStream, ms, bytesToRead);
            ms.Position = 0;

            var presignedUrl = init.PartUrls[partIndex];

            await semaphore.WaitAsync();
            tasks.Add(Task.Run(async () =>
            {
                try
                {
                    using var req = new HttpRequestMessage(HttpMethod.Put, presignedUrl)
                    {
                        Content = new StreamContent(ms)
                    };

                    // IMPORTANT: Only set Content-Type if it was included when presigning,
                    // otherwise you'll get SignatureDoesNotMatch. [6](https://repost.aws/knowledge-center/s3-presigned-url-signature-mismatch)
                    req.Content.Headers.ContentType =
                        new System.Net.Http.Headers.MediaTypeHeaderValue(init.ContentType);

                    using var resp = await Http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead);
                    resp.EnsureSuccessStatusCode();

                    var etag = resp.Headers.ETag?.Tag;
                    if (string.IsNullOrEmpty(etag) && resp.Headers.TryGetValues("ETag", out var vals))
                        etag = vals.FirstOrDefault();

                    etags[partIndex] = etag ?? throw new InvalidOperationException("Missing ETag");

                    Interlocked.Add(ref uploadedBytes, bytesToRead);
                    _progress = 100.0 * uploadedBytes / file.Size;
                    await InvokeAsync(StateHasChanged);
                }
                finally { semaphore.Release(); ms.Dispose(); }
            }));
        }

        await Task.WhenAll(tasks);

        // 3) Complete the multipart upload (server calls S3 CompleteMultipartUpload)
        var completeReq = new CompleteMultipartRequest
        {
            Key = init.Key,
            UploadId = init.UploadId,
            Parts = etags.Select((etag, idx) => new CompletedPart
            {
                PartNumber = idx + 1,
                ETag = etag // keep quotes
            }).ToList()
        };

        var completeResp = await Http.PostAsJsonAsync("https://YOUR_API/complete-multipart", completeReq);
        completeResp.EnsureSuccessStatusCode();

        _status = "Upload completed successfully.";
        _progress = 100;
        StateHasChanged();
    }

    private static async Task CopyFixedBytesAsync(Stream src, Stream dest, int bytesToCopy)
    {
        var buf = new byte[81920];
        int remaining = bytesToCopy;
        while (remaining > 0)
        {
            var read = await src.ReadAsync(buf.AsMemory(0, Math.Min(buf.Length, remaining)));
            if (read == 0) throw new EndOfStreamException("Unexpected EOF.");
            await dest.WriteAsync(buf.AsMemory(0, read));
            remaining -= read;
        }
    }

    // DTOs
    private record InitMultipartRequest(string FileName, string ContentType, long PartSizeBytes, long TotalSizeBytes);
    private class InitMultipartResponse
    {
        public string UploadId { get; set; } = default!;
        public string Key { get; set; } = default!;
        public List<string> PartUrls { get; set; } = new();
        public string ContentType { get; set; } = "application/octet-stream";
    }
    private record CompletedPart
    {
        public int PartNumber { get; init; }
        public string ETag { get; init; } = default!;
    }
    private record CompleteMultipartRequest
    {
        public string Key { get; init; } = default!;
        public string UploadId { get; init; } = default!;
        public List<CompletedPart> Parts { get; init; } = new();
    }
}
